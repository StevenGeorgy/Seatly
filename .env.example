# Seatly — environment template (safe to commit).
# Copy to .env at the repo root and fill in secrets. Never commit .env.
#
# apps/web (Vite) loads this file from the repo root via envDir — no duplicate .env under apps/web required.

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# apps/web (Vite) — same URL and anon key as above; only these are exposed to the SPA bundle
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API (Edge Functions)
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (emails)
RESEND_API_KEY=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# VAPI (voice AI)
VAPI_API_KEY=

# Cron (nightly Edge Functions)
CRON_SECRET=

# Sentry (error tracking)
SENTRY_DSN=

# Optional: Next.js /api/auth/repair-profile
# SEATLY_STAFF_RESTAURANT_ID=
# SEATLY_AUTO_STAFF_PROFILE=1
